---
import BaseLayout from "../layouts/BaseLayout.astro";

const whatIDo = [
  {
    title: "Application development",
    desc: "End-to-end Zoho Creator & React apps, owned from spec to deployment.",
  },
  {
    title: "Data & integrations",
    desc: "Pipelines, ETL migrations and third-party integrations that just work.",
  },
  {
    title: "Interface & UX",
    desc: "Responsive, cross-device UI with Figma, Tailwind & shadcn.",
  },
];

const experience = [
  {
    title: "Zoho Developer",
    org: "Heylo Housing · Remote",
    dates: "Dec 2025 — Present",
    bullets: [
      "Architected cross-organizational data synchronization with automated Zoho Books scripts for real-time vendor replication.",
      "Led end-to-end data migration & ETL of complex legacy financial data with 100% integrity.",
      "Engineered third-party integrations connecting Zoho Analytics & Creator to FloQast, automating closing cycles.",
      "Delivered full-stack business modules and workflows in Deluge, digitising manual operations.",
    ],
  },
  {
    title: "Senior App Developer",
    org: "Zoho Corporation · Chennai",
    dates: "Apr 2022 — Jul 2025",
    bullets: [
      "Designed, built & deployed custom Zoho Creator applications with full-lifecycle ownership.",
      "Used Figma, React.js & modern web tech to ship responsive, cross-device interfaces.",
      "Enhanced functionality with Deluge scripting and custom performance logic.",
      "Mentored junior developers, raising code quality and adherence to standards.",
    ],
  },
  {
    title: "Technical Support Engineer",
    org: "Zoho Corporation · Chennai",
    dates: "Feb 2018 — Mar 2022",
    bullets: [
      "Supported cloud products (Zoho Invoice & Subscriptions) over phone, email & chat with timely resolutions.",
      "Ran product demos and webinars, lifting customer engagement and driving sales growth.",
    ],
  },
];

const facts = [
  { label: "Location", value: "Singapore" },
  { label: "Experience", value: "7+ years" },
  { label: "Focus", value: "Zoho · React" },
  { label: "Currently", value: "Heylo Housing" },
];
---

<BaseLayout title="About — Akhil Venkatesh" active="about">
  <section class="section intro-section">
    <div class="intro-header">
      <div class="portrait-slot-small" aria-hidden="true">Photo</div>
      <div>
        <div class="eyebrow">// about</div>
        <h1 class="intro-title">Seven years turning tangled operations into calm software.</h1>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="intro-grid section-top-rule">
      <div>
        <p class="lead">
          I've spent most of my career deep inside the Zoho ecosystem, with a modern front end in React and
          TypeScript — building scalable, user-centred applications for teams across housing, finance and
          SaaS.
        </p>
        <p class="body-text">
          My work runs the full application lifecycle: architecting cross-organizational data pipelines,
          migrating complex legacy data with zero loss, and shaping the responsive interfaces people rely
          on every day.
        </p>
        <p class="body-text">
          I care about the unglamorous parts — the automations that quietly remove manual work — as much as
          the parts you can see. Good internal tools deserve product-grade craft.
        </p>
      </div>
      <div class="facts-list">
        {facts.map((f) => (
          <div class="fact-row">
            <span class="mono fact-label">{f.label}</span>
            <span class="fact-value">{f.value}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <h2 class="section-heading section-top-rule">What I do</h2>
    <div class="do-grid">
      {whatIDo.map((d) => (
        <div class="surface do-card">
          <div class="do-icon"><span class="do-icon-dot"></span></div>
          <h3 class="do-title">{d.title}</h3>
          <p class="do-desc">{d.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="section experience-section">
    <div class="experience-heading section-top-rule">
      <span class="heading-dot"></span>
      <h2 class="section-heading" style="margin:0;">Experience</h2>
    </div>
    <div>
      {experience.map((role, i) => (
        <div class="role-row" style={i === experience.length - 1 ? "border-bottom:1px solid var(--border);" : undefined}>
          <div>
            <div class="role-title">{role.title}</div>
            <div class="role-org">{role.org}</div>
            <div class="mono role-dates">{role.dates}</div>
          </div>
          <ul class="role-bullets">
            {role.bullets.map((b) => <li>{b}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <h2 class="section-heading section-top-rule">Education</h2>
    <div class="surface education-card">
      <div>
        <div class="edu-title">B.Tech, Computer Science</div>
        <div class="edu-org">Hindustan University · OMR, India</div>
      </div>
      <span class="mono edu-dates">Jun 2014 — Jul 2018</span>
    </div>
  </section>
</BaseLayout>

<style>
  .intro-section {
    padding-top: 80px;
    padding-bottom: 48px;
  }
  .intro-header {
    display: flex;
    align-items: flex-start;
    gap: 24px;
  }
  .portrait-slot-small {
    flex-shrink: 0;
    width: 88px;
    height: 88px;
    border-radius: 18px;
    background: var(--surface);
    border: 1px dashed var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--faint);
    font-size: 11px;
  }
  .intro-title {
    font-size: 60px;
    font-weight: 700;
    letter-spacing: -0.03em;
    max-width: 820px;
    line-height: 1.04;
  }
  .intro-grid {
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    gap: 56px;
    padding-top: 44px;
  }
  .lead {
    font-size: 20px;
    line-height: 1.65;
    color: var(--ink);
    margin-bottom: 22px;
  }
  .body-text {
    font-size: 17px;
    line-height: 1.7;
    color: var(--muted);
    max-width: 600px;
    margin-bottom: 22px;
  }
  .body-text:last-child {
    margin-bottom: 0;
  }
  .facts-list {
    display: flex;
    flex-direction: column;
  }
  .fact-row {
    display: flex;
    justify-content: space-between;
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
  }
  .fact-label {
    color: var(--faint);
    font-size: 14px;
  }
  .fact-value {
    font-size: 15px;
    font-weight: 500;
  }

  .do-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 22px;
  }
  .do-card {
    padding: 30px;
  }
  .do-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: var(--accent-soft);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .do-icon-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--accent);
  }
  .do-title {
    font-size: 19px;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .do-desc {
    font-size: 15px;
    line-height: 1.6;
    color: var(--muted);
  }

  .experience-heading {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }
  .heading-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
  }
  .role-row {
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: 36px;
    padding: 32px 0;
    border-top: 1px solid var(--border);
  }
  .role-row:first-child {
    margin-top: 24px;
  }
  .role-title {
    font-size: 20px;
    font-weight: 700;
  }
  .role-org {
    font-size: 15px;
    color: var(--muted);
    margin-top: 4px;
  }
  .role-dates {
    font-size: 13px;
    color: var(--accent-on-soft);
    margin-top: 12px;
  }
  .role-bullets {
    margin: 0;
    padding-left: 20px;
    display: flex;
    flex-direction: column;
    gap: 11px;
    font-size: 16px;
    line-height: 1.55;
    color: var(--muted);
  }

  .education-card {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 8px;
    padding: 28px 32px;
  }
  .edu-title {
    font-size: 18px;
    font-weight: 700;
  }
  .edu-org {
    font-size: 15px;
    color: var(--muted);
    margin-top: 4px;
  }
  .edu-dates {
    font-size: 13px;
    color: var(--faint);
  }

  @media (max-width: 860px) {
    .intro-grid,
    .do-grid,
    .role-row {
      grid-template-columns: 1fr;
    }
    .intro-header {
      flex-direction: column;
    }
  }
</style>
