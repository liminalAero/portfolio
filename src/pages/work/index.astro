---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { WORK } from "../../data/work";
import { PROJECTS } from "../../data/projects";

function uniqueTags(items: { tags: string[] }[]): string[] {
  const uniq: string[] = [];
  items.forEach((p) => p.tags.forEach((t) => { if (!uniq.includes(t)) uniq.push(t); }));
  return ["All", ...uniq];
}

const workTags = uniqueTags(WORK);
const projectTags = uniqueTags(PROJECTS);
---

<BaseLayout title="Work — Akhil Venkatesh" active="work">
  <section class="section header-section">
    <div class="eyebrow" data-eyebrow-work>// selected work</div>
    <div class="eyebrow" data-eyebrow-projects hidden>// personal projects</div>
    <h1 class="page-title" data-heading-work>Projects I&rsquo;ve shipped end&#8209;to&#8209;end.</h1>
    <h1 class="page-title" data-heading-projects hidden>Things I build for fun.</h1>
    <p class="page-blurb" data-blurb-work>
      A selection of applications, data pipelines and integrations built across the Zoho ecosystem — owned
      from spec through deployment.
    </p>
    <p class="page-blurb" data-blurb-projects hidden>
      Side projects, experiments and open-source tools — where I try ideas outside of client work.
    </p>
  </section>

  <section class="section tabs-section">
    <div class="tabs-bar">
      <button type="button" class="tab-btn active" data-tab-btn="work">Work</button>
      <button type="button" class="tab-btn" data-tab-btn="projects">Projects</button>
    </div>
  </section>

  <div class="tab-panel" data-tab-panel="work">
    <section class="section tag-section">
      <div class="tag-row">
        {workTags.map((t) => <button type="button" class="tag-pill" data-tag-btn={t}>{t}</button>)}
        <span class="mono count-text" data-count></span>
      </div>
    </section>
    <section class="section grid-section">
      <div class="card-grid">
        {WORK.map((p) => (
          <a href={`/work/${p.slug}`} class="card surface" data-card data-tags={p.tags.join(",")}>
            <div class="card-blob"></div>
            <div class="mono card-meta">{p.category} · {p.year}</div>
            <h3 class="card-title">{p.title}</h3>
            <p class="card-desc">{p.desc}</p>
            <div class="card-tags">
              {p.tags.map((t) => <span class="tag-chip">{t}</span>)}
            </div>
          </a>
        ))}
      </div>
      <div class="empty-state mono" data-empty hidden>Nothing tagged &ldquo;<span data-empty-tag></span>&rdquo; yet.</div>
    </section>
  </div>

  <div class="tab-panel" data-tab-panel="projects" hidden>
    <section class="section tag-section">
      <div class="tag-row">
        {projectTags.map((t) => <button type="button" class="tag-pill" data-tag-btn={t}>{t}</button>)}
        <span class="mono count-text" data-count></span>
      </div>
    </section>
    <section class="section grid-section">
      <div class="card-grid">
        {PROJECTS.map((p) => (
          <a href={p.live || "#"} class="card surface" data-card data-tags={p.tags.join(",")}>
            <div class="card-blob"></div>
            <div class="mono card-meta">{p.category} · {p.year}</div>
            <h3 class="card-title">{p.title}</h3>
            <p class="card-desc">{p.desc}</p>
            <div class="card-tags">
              {p.tags.map((t) => <span class="tag-chip">{t}</span>)}
              {p.live && <span class="mono live-tag">Live ↗</span>}
            </div>
          </a>
        ))}
      </div>
      <div class="empty-state mono" data-empty hidden>Nothing tagged &ldquo;<span data-empty-tag></span>&rdquo; yet.</div>
    </section>
  </div>
</BaseLayout>

<style>
  .header-section {
    padding-top: 80px;
    padding-bottom: 32px;
  }
  .page-title {
    font-size: 60px;
    font-weight: 700;
    letter-spacing: -0.03em;
    max-width: 820px;
    line-height: 1.04;
  }
  .page-blurb {
    margin-top: 24px;
    font-size: 19px;
    line-height: 1.6;
    color: var(--muted);
    max-width: 600px;
  }

  .tabs-section {
    padding-top: 16px;
    padding-bottom: 0;
  }
  .tabs-bar {
    display: inline-flex;
    gap: 4px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 5px;
  }
  .tab-btn {
    cursor: pointer;
    font-family: "Ubuntu", sans-serif;
    font-size: 15px;
    font-weight: 500;
    color: var(--muted);
    background: transparent;
    border: none;
    padding: 9px 22px;
    border-radius: 8px;
  }
  .tab-btn.active {
    font-weight: 600;
    color: var(--ink);
    background: var(--bg);
  }

  .tag-section {
    padding-top: 24px;
    padding-bottom: 8px;
  }
  .tag-row {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: center;
  }
  .tag-pill {
    cursor: pointer;
    font-family: "Ubuntu", sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: var(--muted);
    background: transparent;
    border: 1px solid var(--border);
    padding: 8px 15px;
    border-radius: 999px;
  }
  .tag-pill.active {
    font-weight: 600;
    color: var(--accent-ink);
    background: var(--accent);
    border-color: var(--accent);
  }
  .count-text {
    font-size: 13px;
    color: var(--faint);
    margin-left: 6px;
  }

  .grid-section {
    padding-top: 24px;
    padding-bottom: 72px;
  }
  .card-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px;
  }
  .card {
    text-decoration: none;
    color: inherit;
    padding: 34px;
    position: relative;
    overflow: hidden;
  }
  .card[hidden] {
    display: none;
  }
  .card-blob {
    position: absolute;
    top: 30px;
    right: 30px;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.9;
  }
  .card-meta {
    font-size: 13px;
    color: var(--accent-on-soft);
    margin-bottom: 52px;
  }
  .card-title {
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 10px;
  }
  .card-desc {
    font-size: 15px;
    line-height: 1.6;
    color: var(--muted);
    max-width: 400px;
    margin-bottom: 20px;
  }
  .card-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    align-items: center;
  }
  .live-tag {
    font-size: 12px;
    color: var(--accent-on-soft);
    margin-left: auto;
  }

  .empty-state {
    border: 1px dashed var(--border);
    border-radius: 18px;
    padding: 56px;
    text-align: center;
    color: var(--faint);
    font-size: 14px;
  }

  @media (max-width: 860px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Restart a CSS animation on an element by toggling its class via a forced reflow.
  function replay(el: HTMLElement, className: string) {
    el.classList.remove(className);
    void el.offsetWidth;
    el.classList.add(className);
  }

  function setupTabs() {
    const tabBtns = document.querySelectorAll<HTMLButtonElement>("[data-tab-btn]");
    const panels = document.querySelectorAll<HTMLElement>("[data-tab-panel]");
    const headerBits = ["eyebrow", "heading", "blurb"] as const;

    function showTab(tab: string) {
      panels.forEach((p) => {
        const show = p.dataset.tabPanel === tab;
        p.hidden = !show;
        if (show) replay(p, "fade-in");
      });
      tabBtns.forEach((b) => b.classList.toggle("active", b.dataset.tabBtn === tab));
      headerBits.forEach((bit) => {
        document.querySelectorAll<HTMLElement>(`[data-${bit}-work]`).forEach((el) => (el.hidden = tab !== "work"));
        document.querySelectorAll<HTMLElement>(`[data-${bit}-projects]`).forEach((el) => (el.hidden = tab !== "projects"));
      });
      const panel = document.querySelector<HTMLElement>(`[data-tab-panel="${tab}"]`);
      panel?.querySelector<HTMLButtonElement>('[data-tag-btn="All"]')?.click();
    }

    tabBtns.forEach((btn) => btn.addEventListener("click", () => showTab(btn.dataset.tabBtn!)));
  }

  function setupTagFilters() {
    document.querySelectorAll<HTMLElement>("[data-tab-panel]").forEach((panel) => {
      const tagBtns = panel.querySelectorAll<HTMLButtonElement>("[data-tag-btn]");
      const cards = panel.querySelectorAll<HTMLAnchorElement>("[data-card]");
      const countEl = panel.querySelector<HTMLElement>("[data-count]");
      const emptyEl = panel.querySelector<HTMLElement>("[data-empty]");
      const emptyTagEl = panel.querySelector<HTMLElement>("[data-empty-tag]");

      function applyTag(tag: string) {
        let visible = 0;
        cards.forEach((card) => {
          const tags = (card.dataset.tags ?? "").split(",");
          const show = tag === "All" || tags.includes(tag);
          card.hidden = !show;
          if (show) {
            replay(card, "fade-in");
            visible++;
          }
        });
        if (countEl) countEl.textContent = `${visible} ${visible === 1 ? "item" : "items"}`;
        if (emptyEl) emptyEl.hidden = visible !== 0;
        if (emptyTagEl) emptyTagEl.textContent = tag;
        tagBtns.forEach((b) => b.classList.toggle("active", b.dataset.tagBtn === tag));
      }

      tagBtns.forEach((btn) => btn.addEventListener("click", () => applyTag(btn.dataset.tagBtn!)));
      applyTag("All");
    });
  }

  function init() {
    setupTabs();
    setupTagFilters();
  }

  document.addEventListener("astro:page-load", init);
</script>
