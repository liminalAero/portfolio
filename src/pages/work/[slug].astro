---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { WORK_ORDER, getWorkItem, getNextWork } from "../../data/work";

export function getStaticPaths() {
  return WORK_ORDER.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const proj = getWorkItem(slug!);
const next = getNextWork(slug!);
---

<BaseLayout title={`${proj.title} — Akhil Venkatesh`} active="work">
  <section class="container-narrow header-section">
    <a href="/work" class="mono back-link">← Selected work</a>
    <div class="mono meta-eyebrow">{proj.category} · {proj.year}</div>
    <h1 class="title">{proj.title}</h1>
    <p class="summary">{proj.summary}</p>
    {proj.live && (
      <div class="live-cta">
        <a href={proj.live} target="_blank" rel="noopener" class="btn btn-primary">
          <span class="live-dot"></span>View live project ↗
        </a>
      </div>
    )}
  </section>

  <section class="container-narrow meta-section">
    <div class="meta-grid">
      <div>
        <div class="mono meta-label">ROLE</div>
        <div class="meta-value">{proj.role}</div>
      </div>
      <div>
        <div class="mono meta-label">TIMELINE</div>
        <div class="meta-value">{proj.timeline}</div>
      </div>
      <div>
        <div class="mono meta-label">STACK</div>
        <div class="stack-tags">
          {proj.stack.map((tech) => <span class="tag-chip">{tech}</span>)}
        </div>
      </div>
    </div>
  </section>

  <section class="container-narrow stats-section">
    <div class="stats-grid">
      {proj.stats.map((stat) => (
        <div class="surface stat-card">
          <div class="stat-value">{stat.value}</div>
          <div class="stat-label">{stat.label}</div>
        </div>
      ))}
    </div>
  </section>

  <section class="container-article body-section">
    {proj.sections.map((sec) => (
      <div class="body-block">
        <h2 class="body-heading">{sec.heading}</h2>
        {sec.paragraphs.map((para) => <p class="body-para">{para}</p>)}
      </div>
    ))}
  </section>

  <section class="container-narrow next-section">
    <a href={`/work/${next.slug}`} class="surface next-card">
      <div>
        <div class="mono next-label">NEXT PROJECT</div>
        <div class="next-title">{next.title}</div>
      </div>
      <span class="btn btn-primary next-btn">View →</span>
    </a>
  </section>
</BaseLayout>

<style>
  .header-section {
    padding-top: 56px;
    padding-bottom: 8px;
  }
  .back-link {
    font-size: 14px;
    color: var(--muted);
    text-decoration: none;
  }
  .meta-eyebrow {
    font-size: 14px;
    color: var(--accent-on-soft);
    margin: 32px 0 16px;
  }
  .title {
    font-size: 54px;
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.04;
  }
  .summary {
    margin-top: 24px;
    font-size: 20px;
    line-height: 1.6;
    color: var(--muted);
    max-width: 660px;
  }
  .live-cta {
    margin-top: 32px;
  }
  .live-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent-ink);
  }

  .meta-section {
    padding-top: 40px;
    padding-bottom: 40px;
  }
  .meta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1.4fr;
    gap: 28px;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 28px 0;
  }
  .meta-label {
    font-size: 12px;
    color: var(--faint);
    margin-bottom: 8px;
  }
  .meta-value {
    font-size: 16px;
    font-weight: 500;
  }
  .stack-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .stats-section {
    padding-top: 0;
    padding-bottom: 8px;
  }
  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 18px;
  }
  .stat-card {
    padding: 26px;
  }
  .stat-value {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--accent);
  }
  .stat-label {
    font-size: 14px;
    color: var(--muted);
    margin-top: 6px;
  }

  .body-section {
    padding-top: 48px;
    padding-bottom: 24px;
  }
  .body-block {
    margin-bottom: 40px;
  }
  .body-heading {
    font-size: 26px;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: 16px;
  }
  .body-para {
    font-size: 18px;
    line-height: 1.7;
    color: var(--muted);
    margin-bottom: 16px;
  }

  .next-section {
    padding-top: 16px;
    padding-bottom: 72px;
  }
  .next-card {
    text-decoration: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
    padding: 32px 40px;
    color: inherit;
  }
  .next-label {
    font-size: 13px;
    color: var(--faint);
    margin-bottom: 8px;
  }
  .next-title {
    font-size: 24px;
    font-weight: 700;
    color: var(--ink);
  }
  .next-btn {
    white-space: nowrap;
  }

  @media (max-width: 860px) {
    .meta-grid,
    .stats-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
