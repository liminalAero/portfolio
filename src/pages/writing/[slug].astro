---
import { getCollection, getEntry, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({ params: { slug: post.id } }));
}

const { slug } = Astro.params;
const posts = (await getCollection("posts")).sort((a, b) => a.data.order - b.data.order);
const post = (await getEntry("posts", slug!))!;
const { Content } = await render(post);

const i = posts.findIndex((p) => p.id === post.id);
const next = posts[(i + 1) % posts.length];
---

<BaseLayout title={`${post.data.title} — Akhil Venkatesh`} active="writing">
  <article class="container-article header-section">
    <a href="/writing" class="mono back-link">← Writing</a>
    <div class="mono post-meta">
      <span>{post.data.date}</span><span class="dot-sep">·</span><span class="faint-text">{post.data.read}</span>
    </div>
    <h1 class="title">{post.data.title}</h1>
    <p class="subtitle">{post.data.subtitle}</p>
  </article>

  <div class="container-article body-section">
    <div class="body-inner">
      <Content />
    </div>
  </div>

  <div class="container-article author-section">
    <div class="author-row">
      <div class="author-avatar">A</div>
      <div>
        <div class="author-name">Akhil Venkatesh</div>
        <div class="author-role">Enterprise Application Developer · Singapore</div>
      </div>
    </div>
  </div>

  <section class="container-article next-section">
    <a href={`/writing/${next.id}`} class="surface next-card">
      <div>
        <div class="mono next-label">NEXT POST</div>
        <div class="next-title">{next.data.title}</div>
      </div>
      <span class="btn btn-primary next-btn">Read →</span>
    </a>
  </section>
</BaseLayout>

<style>
  .header-section {
    padding-top: 56px;
    padding-bottom: 8px;
  }
  .back-link {
    font-size: 14px;
    color: var(--muted);
    text-decoration: none;
  }
  .post-meta {
    display: flex;
    gap: 16px;
    align-items: center;
    margin: 32px 0 18px;
    font-size: 13px;
    color: var(--accent-on-soft);
  }
  .dot-sep,
  .faint-text {
    color: var(--faint);
  }
  .title {
    font-size: 46px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.08;
  }
  .subtitle {
    margin-top: 22px;
    font-size: 20px;
    line-height: 1.55;
    color: var(--muted);
  }

  .body-section {
    padding-top: 32px;
    padding-bottom: 8px;
  }
  .body-inner {
    border-top: 1px solid var(--border);
    padding-top: 36px;
  }
  .body-inner :global(h2) {
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: 34px 0 14px;
  }
  .body-inner :global(p) {
    font-size: 18px;
    line-height: 1.75;
    color: var(--muted);
    margin: 0 0 18px;
  }
  .body-inner :global(> *:first-child) {
    margin-top: 0;
  }

  .author-section {
    padding-top: 8px;
    padding-bottom: 32px;
  }
  .author-row {
    display: flex;
    align-items: center;
    gap: 14px;
    border-top: 1px solid var(--border);
    padding-top: 28px;
  }
  .author-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--accent-soft);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    color: var(--accent-on-soft);
  }
  .author-name {
    font-size: 16px;
    font-weight: 700;
  }
  .author-role {
    font-size: 14px;
    color: var(--muted);
  }

  .next-section {
    padding-top: 16px;
    padding-bottom: 72px;
  }
  .next-card {
    text-decoration: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
    padding: 30px 36px;
    color: inherit;
  }
  .next-label {
    font-size: 13px;
    color: var(--faint);
    margin-bottom: 8px;
  }
  .next-title {
    font-size: 20px;
    font-weight: 700;
    color: var(--ink);
    max-width: 440px;
  }
  .next-btn {
    white-space: nowrap;
  }
</style>
