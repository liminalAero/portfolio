---
import { ClientRouter } from "astro:transitions";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  active?: "work" | "about" | "writing" | "contact" | "";
}

const { title, description = "Akhil Venkatesh — Enterprise Application Developer", active = "" } = Astro.props;
---

<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Ubuntu:wght@400;500;700&family=Ubuntu+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline data-astro-rerun>
      (function () {
        try {
          var theme = localStorage.getItem("pf-theme") || "dark";
          document.documentElement.setAttribute("data-theme", theme);
        } catch (e) {
          document.documentElement.setAttribute("data-theme", "dark");
        }
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <Nav active={active} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
